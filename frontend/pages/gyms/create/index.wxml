<view class="page-container">
  <navbar
    menuOpen="{{menuOpen}}"
    bind:toggleMenu="handleMenuToggle"
  />

  <view class="main-container">
    <view class="page-header">
      <text class="page-title">添加健身房</text>
    </view>

    <view class="form-container">
      <view class="form-item">
        <text class="form-label">健身房名称</text>
        <input
          class="form-input"
          placeholder="请输入健身房名称"
          value="{{name}}"
          bindinput="handleNameChange"
        />
        <text wx:if="{{errors.name}}" class="error-message">{{errors.name}}</text>
      </view>

      <view class="form-item">
        <text class="form-label">地址（选填）</text>
        <textarea
          class="form-textarea"
          placeholder="请输入健身房地址（选填）"
          value="{{address}}"
          bindinput="handleAddressChange"
          auto-height
        />
      </view>

      <button
        class="submit-button"
        bindtap="handleSubmit"
        disabled="{{loading}}"
      >
        <text class="submit-button-text">{{loading ? '提交中...' : '保存'}}</text>
      </button>
    </view>
  </view>

  <tabbar />
</view>
