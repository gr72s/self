<view class="page-container">
  <view class="main-container">
    <view class="page-header">
      <text class="page-title">新建动作</text>
    </view>

    <form class="exercise-form" bindsubmit="handleSubmit">
      <view class="form-section">
        <text class="section-title">基本信息</text>
        <view class="form-item">
          <text class="form-label">名称 *</text>
          <input class="form-input" placeholder="请输入动作名称" value="{{name}}" bindinput="handleNameChange" />
        </view>
        <view class="form-item">
          <text class="form-label">原名（选填）</text>
          <input class="form-input" placeholder="请输入原名" value="{{originName}}" bindinput="handleOriginNameChange" />
        </view>
        <view class="form-item">
          <text class="form-label">要点（选填）</text>
          <textarea class="form-textarea" placeholder="请输入动作要点" value="{{keypoint}}" bindinput="handleKeypointChange" />
        </view>
        <view class="form-item">
          <text class="form-label">描述（选填）</text>
          <textarea class="form-textarea" placeholder="请输入动作描述" value="{{description}}" bindinput="handleDescriptionChange" />
        </view>
      </view>

      <view class="form-section">
        <text class="section-title">肌肉</text>
        <view class="form-item">
          <text class="form-label">主要肌肉 *</text>
          <view class="muscles-container">
            <view wx:for="{{muscles}}" wx:key="id" class="muscle-item" bindtap="toggleMainMuscle" data-id="{{item.id}}">
              <view class="muscle-checkbox {{selectedMainMuscles.includes(item.id) ? 'checked' : ''}}">
                <text wx:if="{{selectedMainMuscles.includes(item.id)}}" class="checkbox-icon">✓</text>
              </view>
              <text class="muscle-name">{{item.name}}</text>
            </view>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">辅助肌肉（选填）</text>
          <view class="muscles-container">
            <view wx:for="{{muscles}}" wx:key="id" class="muscle-item" bindtap="toggleSupportMuscle" data-id="{{item.id}}">
              <view class="muscle-checkbox {{selectedSupportMuscles.includes(item.id) ? 'checked' : ''}}">
                <text wx:if="{{selectedSupportMuscles.includes(item.id)}}" class="checkbox-icon">✓</text>
              </view>
              <text class="muscle-name">{{item.name}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="form-section">
        <text class="section-title">提示要点</text>
        <view class="form-item">
          <text class="form-label">可添加多条</text>
          <view class="cues-container">
            <view wx:for="{{cues}}" wx:key="index" class="cue-item">
              <input class="cue-input" placeholder="请输入提示" value="{{item}}" bindinput="handleCueChange" data-index="{{index}}" />
              <button class="remove-cue-button" bindtap="removeCue" data-index="{{index}}">-</button>
            </view>
            <button class="add-cue-button" bindtap="addCue">+ 添加提示</button>
          </view>
        </view>
      </view>

      <view class="form-actions">
        <button class="cancel-button" bindtap="navigateBack">取消</button>
        <button class="submit-button" form-type="submit" wx:if="{{!submitting}}">新建动作</button>
        <button class="submit-button" disabled wx:else>创建中...</button>
      </view>
    </form>
  </view>
</view>
