<view class="page-container">
  <view class="main-container">
    <view class="section-title">
      <text>肌肉</text>
      <view class="toolbar-right">
        <view class="button icon-button" bindtap="handleRefresh">
          <text>↻</text>
        </view>
        <view class="button primary create-button" bindtap="handleAddMuscle">
          <text class="button-text">+ 新建</text>
        </view>
      </view>
    </view>

    <view class="table">
      <block wx:if="{{loading}}">
        <view class="loading">
          <view class="loading-spinner"></view>
          <text>加载中...</text>
        </view>
      </block>
      <block wx:elif="{{error}}">
        <view class="empty">
          <text class="empty-icon">⚠</text>
          <text class="empty-text">{{error}}</text>
          <view class="button secondary" bindtap="loadMuscles">
            <text class="button-text">重试</text>
          </view>
        </view>
      </block>
      <block wx:elif="{{muscles.length === 0}}">
        <view class="empty">
          <text class="empty-icon">💪</text>
          <text class="empty-text">暂无肌肉</text>
          <text class="empty-subtext">创建第一个肌肉开始使用</text>
          <view class="button primary create-button" bindtap="handleAddMuscle">
            <text class="button-text">新建首个肌肉</text>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="table-body">
          <view wx:for="{{muscles}}" wx:key="id" class="table-row">
            <view class="table-cell">
              <view class="muscle-meta">
                <view class="muscle-top">
                  <text class="muscle-name">{{item.name}}</text>
                  <view class="table-actions">
                    <view class="button icon-button" bindtap="handleEditMuscle" data-id="{{item.id}}">
                      <text>✎</text>
                    </view>
                    <view class="button icon-button delete" bindtap="handleDeleteMuscle" data-id="{{item.id}}">
                      <text>🗑</text>
                    </view>
                  </view>
                </view>
                <text class="muscle-function">{{item.function || '未填写功能'}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view wx:if="{{showDeleteConfirm}}" class="modal-overlay">
      <view class="modal-content">
        <text class="modal-title">确认删除</text>
        <text class="modal-message">确定删除该肌肉吗？</text>
        <view class="modal-buttons">
          <view class="button secondary" bindtap="cancelDelete">
            <text class="button-text">取消</text>
          </view>
          <view class="button primary delete" bindtap="confirmDelete">
            <text class="button-text">删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
