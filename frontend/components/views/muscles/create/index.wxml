<view class="page-container">
  <view class="main-container">
    <view class="page-header">
      <text class="page-title">新建肌肉</text>
    </view>

    <view class="form-container">
      <view class="form-item">
        <text class="form-label">肌肉名称 *</text>
        <input class="form-input" placeholder="请输入肌肉名称" value="{{name}}" bindinput="handleNameChange" />
        <text wx:if="{{errors.name}}" class="error-message">{{errors.name}}</text>
      </view>

      <view class="form-item">
        <text class="form-label">功能（选填）</text>
        <input class="form-input" placeholder="请输入肌肉功能" value="{{functionText}}" bindinput="handleFunctionChange" />
      </view>

      <view class="form-item">
        <text class="form-label">原名（选填）</text>
        <input class="form-input" placeholder="请输入原名" value="{{originName}}" bindinput="handleOriginNameChange" />
      </view>

      <button class="submit-button" bindtap="handleSubmit" disabled="{{loading}}">
        <text class="submit-button-text">{{loading ? '提交中...' : '保存'}}</text>
      </button>
    </view>
  </view>
</view>
