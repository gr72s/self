<view class="page-container">
  <view class="main-container">
    <view class="section-title">
      <text>训练计划</text>
      <view class="toolbar-right">
        <view class="button icon-button" bindtap="handleRefresh">
          <text>↻</text>
        </view>
        <view class="button primary create-button" bindtap="navigateToCreate">
          <text class="button-text">+ 新建</text>
        </view>
      </view>
    </view>

    <view class="table">
      <block wx:if="{{loading}}">
        <view class="loading">
          <view class="loading-spinner"></view>
          <text>加载中...</text>
        </view>
      </block>
      <block wx:elif="{{routines.length === 0}}">
        <view class="empty">
          <text class="empty-icon">📄</text>
          <text class="empty-text">暂无训练计划</text>
          <text class="empty-subtext">创建第一个训练计划开始使用</text>
          <view class="button primary create-button" bindtap="navigateToCreate">
            <text class="button-text">新建首个训练计划</text>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="table-header">
          <view class="table-header-cell">计划</view>
          <view class="table-header-cell">动作数</view>
          <view class="table-header-cell">目标数</view>
          <view class="table-header-cell">描述</view>
          <view class="table-header-cell" style="text-align: right;">操作</view>
        </view>
        <view class="table-body">
          <view wx:for="{{routines}}" wx:key="id" class="table-row">
            <view class="table-cell">
              <text class="routine-name">{{item.name}}</text>
            </view>
            <view class="table-cell">
              <text>{{item.slot_count}}</text>
            </view>
            <view class="table-cell">
              <text>{{item.target_count}}</text>
            </view>
            <view class="table-cell">
              <text class="routine-description">{{item.description || '暂无描述'}}</text>
            </view>
            <view class="table-cell" style="text-align: right;">
              <view class="table-actions">
                <view class="button icon-button" bindtap="navigateToEdit" data-id="{{item.id}}">
                  <text>✎</text>
                </view>
                <view class="button icon-button delete" bindtap="confirmDelete" data-id="{{item.id}}">
                  <text>🗑</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
