<view class="page-container">
  <view class="main-container">
    <view class="page-header">
      <text class="page-title">新建训练</text>
    </view>

    <form class="workout-form" bindsubmit="handleSubmit">
      <view class="form-section">
        <text class="section-title">计划</text>
        <view class="form-item">
          <text class="form-label">选择训练计划（选填）</text>
          <view class="select-container">
            <picker bindchange="handleRoutineChange" range="{{routines}}" range-key="name" value="{{selectedRoutineIndex}}">
              <view class="picker-view">
                {{selectedRoutine ? selectedRoutine.name : '请选择训练计划'}}
              </view>
            </picker>
          </view>
        </view>
      </view>

      <view class="form-section">
        <text class="section-title">健身房</text>
        <view class="form-item">
          <text class="form-label">选择健身房 *</text>
          <view class="select-container">
            <picker bindchange="handleGymChange" range="{{gyms}}" range-key="name" value="{{selectedGymIndex}}">
              <view class="picker-view">
                {{selectedGym ? selectedGym.name : '请选择健身房'}}
              </view>
            </picker>
          </view>
        </view>
      </view>

      <view class="form-section">
        <text class="section-title">目标</text>
        <view class="form-item">
          <text class="form-label">至少选择一项 *</text>
          <view class="targets-container">
            <view wx:for="{{targets}}" wx:key="id" class="target-item" bindtap="toggleTarget" data-id="{{item.id}}">
              <view class="target-checkbox {{selectedTargets.includes(item.id) ? 'checked' : ''}}">
                <text wx:if="{{selectedTargets.includes(item.id)}}" class="checkbox-icon">✓</text>
              </view>
              <text class="target-name">{{item.name}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="form-section">
        <text class="section-title">其他信息</text>
        <view class="form-item">
          <text class="form-label">备注（选填）</text>
          <textarea class="form-textarea" placeholder="填写训练备注" value="{{note}}" bindinput="handleNoteChange"></textarea>
        </view>
      </view>

      <view class="form-actions">
        <button class="cancel-button" bindtap="navigateBack">取消</button>
        <button class="submit-button" form-type="submit" wx:if="{{!submitting}}">新建训练</button>
        <button class="submit-button" disabled wx:else>创建中...</button>
      </view>
    </form>
  </view>
</view>
