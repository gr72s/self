<view class="page-container">
  <view class="main-container">
    <view class="section-title">
      <text>训练记录</text>
      <view class="toolbar-right">
        <view class="button icon-button" bindtap="handleRefresh">
          <text>↻</text>
        </view>
        <view class="button primary create-button" bindtap="navigateToCreate">
          <text class="button-text">+ 新建</text>
        </view>
      </view>
    </view>

    <view class="table">
      <block wx:if="{{loading}}">
        <view class="loading">
          <view class="loading-spinner"></view>
          <text>加载中...</text>
        </view>
      </block>
      <block wx:elif="{{workouts.length === 0}}">
        <view class="empty">
          <text class="empty-icon">📋</text>
          <text class="empty-text">暂无训练记录</text>
          <text class="empty-subtext">创建第一条训练记录开始使用</text>
          <view class="button primary create-button" bindtap="navigateToCreate">
            <text class="button-text">新建首条训练记录</text>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="table-header">
          <view class="table-header-cell">训练</view>
          <view class="table-header-cell">日期</view>
          <view class="table-header-cell">时间</view>
          <view class="table-header-cell">健身房</view>
          <view class="table-header-cell">时长</view>
          <view class="table-header-cell">状态</view>
          <view class="table-header-cell" style="text-align: right;">操作</view>
        </view>
        <view class="table-body">
          <view wx:for="{{workouts}}" wx:key="id" class="table-row">
            <view class="table-cell">
              <text class="workout-name">{{item.routine && item.routine.name ? item.routine.name : '未命名训练'}}</text>
            </view>
            <view class="table-cell">
              <text>{{formatDate(item.startTime)}}</text>
            </view>
            <view class="table-cell">
              <text>{{formatTime(item.startTime)}} - {{item.endTime ? formatTime(item.endTime) : '进行中'}}</text>
            </view>
            <view class="table-cell">
              <text>{{item.gym && item.gym.name ? item.gym.name : '未知健身房'}}</text>
            </view>
            <view class="table-cell">
              <text>{{item.endTime ? calculateDuration(item.startTime, item.endTime) : '-'}}</text>
            </view>
            <view class="table-cell">
              <text class="status {{item.endTime ? 'completed' : 'in-progress'}}">
                {{item.endTime ? '已完成' : '进行中'}}
              </text>
            </view>
            <view class="table-cell" style="text-align: right;">
              <view class="table-actions">
                <view class="button icon-button" bindtap="navigateToDetail" data-id="{{item.id}}">
                  <text>👁</text>
                </view>
                <view class="button icon-button" bindtap="navigateToEdit" data-id="{{item.id}}">
                  <text>✎</text>
                </view>
                <view class="button icon-button delete" bindtap="confirmDelete" data-id="{{item.id}}">
                  <text>🗑</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
