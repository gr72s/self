<view class="page-container">
  <view class="main-container">
    <view class="section-title">
      <text>健身房</text>
      <view class="toolbar-right">
        <view class="button icon-button" bindtap="handleRefresh">
          <text>🔄</text>
        </view>
        <view class="button primary create-button" bindtap="handleAddGym">
          <text class="button-text">+ 新建</text>
        </view>
      </view>
    </view>

    <view class="table">
      <block wx:if="{{loading}}">
        <view class="loading">
          <view class="loading-spinner"></view>
          <text>加载中...</text>
        </view>
      </block>
      <block wx:elif="{{error}}">
        <view class="empty">
          <text class="empty-icon">⚠️</text>
          <text class="empty-text">{{error}}</text>
          <view class="button secondary" bindtap="loadGyms">
            <text class="button-text">重试</text>
          </view>
        </view>
      </block>
      <block wx:elif="{{gyms.length === 0}}">
        <view class="empty">
          <text class="empty-icon">🏟️</text>
          <text class="empty-text">暂无健身房</text>
          <text class="empty-subtext">创建第一个健身房开始使用</text>
          <view class="button primary create-button" bindtap="handleAddGym">
            <text class="button-text">新建首个健身房</text>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="table-header">
          <view class="table-header-cell">健身房</view>
          <view class="table-header-cell">位置</view>
          <view class="table-header-cell" style="text-align: right;">操作</view>
        </view>
        <view class="table-body">
          <view wx:for="{{gyms}}" wx:key="id" class="table-row">
            <view class="table-cell">
              <text class="gym-name">{{item.name}}</text>
            </view>
            <view class="table-cell">
              <text class="gym-address">{{item.location}}</text>
            </view>
            <view class="table-cell" style="text-align: right;">
              <view class="table-actions">
                <view class="button icon-button" bindtap="handleEditGym" data-id="{{item.id}}">
                  <text>✏️</text>
                </view>
                <view class="button icon-button delete" bindtap="handleDeleteGym" data-id="{{item.id}}">
                  <text>🗑️</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>

    <view wx:if="{{showDeleteConfirm}}" class="modal-overlay">
      <view class="modal-content">
        <text class="modal-title">确认删除</text>
        <text class="modal-message">确定删除该健身房吗？</text>
        <view class="modal-buttons">
          <view class="button secondary" bindtap="cancelDelete">
            <text class="button-text">取消</text>
          </view>
          <view class="button primary delete" bindtap="confirmDelete">
            <text class="button-text">删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

