<view class="page-container">
  <view class="main-container">
    <view class="page-header">
      <text class="page-title">编辑健身房</text>
    </view>

    <view wx:if="{{loading}}" class="loading-container">
      <text class="loading-text">加载中...</text>
    </view>

    <view wx:if="{{error}}" class="error-container">
      <text class="error-text">{{error}}</text>
      <button class="retry-button" bindtap="loadGymData">重试</button>
    </view>

    <view wx:if="{{!loading && !error}}" class="form-container">
      <view class="form-item">
        <text class="form-label">健身房名称 *</text>
        <input class="form-input" placeholder="请输入健身房名称" value="{{name}}" bindinput="handleNameChange" />
        <text wx:if="{{errors.name}}" class="error-message">{{errors.name}}</text>
      </view>

      <view class="form-item">
        <text class="form-label">位置（选填）</text>
        <textarea class="form-textarea" placeholder="请输入健身房位置（选填）" value="{{location}}" bindinput="handleLocationChange" auto-height />
      </view>

      <button class="submit-button" bindtap="handleSubmit" disabled="{{submitting}}">
        <text class="submit-button-text">{{submitting ? '提交中...' : '保存'}}</text>
      </button>
    </view>
  </view>
</view>
